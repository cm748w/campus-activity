<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.campusactivity.mapper.ActivityMapper">

    <resultMap id="ActivityResultMap" type="com.example.campusactivity.entity.Activity">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="description" property="description"/>
        <result column="location" property="location"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="register_start" property="registerStart"/>
        <result column="register_end" property="registerEnd"/>
        <result column="max_participants" property="maxParticipants"/>
        <result column="current_participants" property="currentParticipants"/>
        <result column="organizer_id" property="organizerId"/>
        <result column="organizer_name" property="organizerName"/>
        <result column="organizer_contact" property="organizerContact"/>
        <result column="activity_type" property="activityType"/>
        <result column="cover_image" property="coverImage"/>
        <result column="status" property="status"/>
        <result column="reject_reason" property="rejectReason"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="has_registered" property="hasRegistered"/>
        <result column="registration_status" property="registrationStatus"/>
    </resultMap>

    <!-- 分页查询活动列表 -->
    <select id="selectActivityPage" resultMap="ActivityResultMap">
        SELECT a.*,
               CASE WHEN r.id IS NOT NULL THEN TRUE ELSE FALSE END as has_registered,
               r.status as registration_status
        FROM activity a
        LEFT JOIN registration r ON a.id = r.activity_id AND r.user_id = #{userId} AND r.deleted = 0
        WHERE a.deleted = 0
        <!-- 普通用户只能看到已发布和报名中的活动 -->
        AND a.status IN (2, 3, 4)
        <if test="keyword != null and keyword != ''">
            AND (a.title LIKE CONCAT('%', #{keyword}, '%')
            OR a.description LIKE CONCAT('%', #{keyword}, '%')
            OR a.location LIKE CONCAT('%', #{keyword}, '%'))
        </if>
        <if test="activityType != null and activityType != ''">
            AND a.activity_type = #{activityType}
        </if>
        <if test="status != null">
            AND a.status = #{status}
        </if>
        ORDER BY a.create_time DESC
    </select>

    <!-- 根据ID查询活动详情 -->
    <select id="selectActivityById" resultMap="ActivityResultMap">
        SELECT a.*,
               CASE WHEN r.id IS NOT NULL THEN TRUE ELSE FALSE END as has_registered,
               r.status as registration_status
        FROM activity a
        LEFT JOIN registration r ON a.id = r.activity_id AND r.user_id = #{userId} AND r.deleted = 0
        WHERE a.id = #{id} AND a.deleted = 0
    </select>

    <!-- 查询负责人发布的活动列表 -->
    <select id="selectOrganizerActivities" resultMap="ActivityResultMap">
        SELECT a.*
        FROM activity a
        WHERE a.deleted = 0
        AND a.organizer_id = #{organizerId}
        <if test="keyword != null and keyword != ''">
            AND (a.title LIKE CONCAT('%', #{keyword}, '%')
            OR a.location LIKE CONCAT('%', #{keyword}, '%'))
        </if>
        <if test="status != null">
            AND a.status = #{status}
        </if>
        ORDER BY a.create_time DESC
    </select>

</mapper>
